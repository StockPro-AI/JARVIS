# ============================================================
# JARVIS - AI Voice Assistant | Environment Variables
# ============================================================
# 1. Copy this file:  copy .env.example .env
# 2. Fill in your API keys below
# 3. Never commit your .env file (it is in .gitignore)
# ============================================================

# --- Google Gemini API ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- NewsAPI ---
# Get your free key at: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here
